script/source = "# item_swapper.gd
extends Control

# 드래그 상태를 추적하기 위한 변수들
var dragging_slot_index: int = -1
var is_swapping: bool = false
var drag_preview: TextureRect = null

func _ready() -> void:
	# 이 컴포넌트 자체는 마우스 클릭을 막지 않고 통과시킵니다.
	mouse_filter = Control.MOUSE_FILTER_PASS

func _gui_input(event: InputEvent) -> void:
	# 1. 인벤토리 빈 공간이나 슬롯에서 우클릭을 눌렀을 때 (드래그 시작)
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_RIGHT and event.pressed:
		var slot_idx = _get_slot_index_under_mouse()
		
		# 아이템이 존재하는 슬롯을 우클릭한 경우에만 스왑 드래그 시작
		if slot_idx != -1 and slot_idx < inventory_manager.items.size() and inventory_manager.items[slot_idx] != null:
			# 코인인 경우 기존 inventory_slot.gd의 '월드 드롭' 기능이 우선순위를 가지므로,
			# 코인이 아닌 다른 아이템들을 정렬/스왑할 때 이 스워퍼가 작동하도록 방어 코드를 넣습니다.
			var item = inventory_manager.items[slot_idx]
			if item.name == \"Coin\":
				return # 코인은 슬롯 스크립트의 드롭 기능으로 양보
				
			_start_swap_drag(slot_idx, item)

func _input(event: InputEvent) -> void:
	if not is_swapping:
		return
		
	# 2. 마우스를 움직일 때 프리뷰 이미지 위치 갱신
	if event is InputEventMouseMotion:
		_update_preview_position()
		
	# 3. 우클릭을 뗐을 때 (드롭 및 스왑 실행)
	elif event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_RIGHT and not event.pressed:
		_end_swap_drag()

# 드래그 시작 시 프리뷰 생성 및 상태 저장
func _start_swap_drag(slot_index: int, item_data: ItemRes) -> void:
	is_swapping = true
	dragging_slot_index = slot_index
	print(\"🔄 [ItemSwapper] %d번 슬롯 아이템 스왑 시작!\" % slot_index)
	
	# 화면에 따라다닐 임시 아이콘 이미지 생성
	drag_preview = TextureRect.new()
	drag_preview.texture = item_data.icon
	drag_preview.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
	drag_preview.size = Vector2(50, 50)
	drag_preview.modulate.a = 0.7 # 살짝 투명하게
	drag_preview.mouse_filter = Control.MOUSE_FILTER_IGNORE # 프리뷰가 마우스 클릭을 막지 않게 설정
	
	# 최상위 씬에 추가하여 UI 너머에서도 잘 보이도록 함
	get_tree().current_scene.add_child(drag_preview)
	_update_preview_position()
	get_viewport().set_input_as_handled()

# 드래그 종료 및 아이템 데이터 교환(Swap) 로직
func _end_swap_drag() -> void:
	is_swapping = false
	
	if drag_preview:
		drag_preview.queue_free()
		drag_preview = null
		
	var target_slot_index = _get_slot_index_under_mouse()
	
	# 정상적인 인벤토리 슬롯 위에서 마우스를 뗐고, 시작한 슬롯과 다른 슬롯인 경우
	if target_slot_index != -1 and target_slot_index != dragging_slot_index:
		# 데이터 스왑 (A와 B의 자리를 바꿈)
		var temp_item = inventory_manager.items[target_slot_index]
		inventory_manager.items[target_slot_index] = inventory_manager.items[dragging_slot_index]
		inventory_manager.items[dragging_slot_index] = temp_item
		
		print(\"✅ [ItemSwapper] %d번 슬롯과 %d번 슬롯 스왑 완료!\" % [dragging_slot_index, target_slot_index])
		
		# UI 새로고침 요구 (`inventory_ui.gd`가 다시 그리도록 호출)
		if inventory_manager.ui:
			inventory_manager.ui.queue_redraw()
			
	dragging_slot_index = -1
	get_viewport().set_input_as_handled()

# 마우스 위치에 따라 프리뷰 위치 보정
func _update_preview_position() -> void:
	if drag_preview and drag_preview.get_parent():
		var mouse_pos = drag_preview.get_parent().get_local_mouse_position()
		drag_preview.position = mouse_pos - (drag_preview.size / 2)

# 현재 마우스 커서 아래에 있는 슬롯의 인덱스를 찾아내는 헬퍼 함수
func _get_slot_index_under_mouse() -> int:
	# 최상위 Inventory 창 아래에 있는 SlotContainer를 찾습니다.
	var container = find_child(\"SlotContainer\", true, false)
	if not container:
		return -1
		
	var mouse_pos = container.get_local_mouse_position()
	
	# SlotContainer 안의 자식(슬롯)들을 순회하며 마우스가 어느 슬롯 영역 안에 있는지 체크
	for child in container.get_children():
		if child is Control:
			var rect = Rect2(child.position, child.size)
			if rect.has_point(mouse_pos):
				return child.get_index() # 몇 번째 슬롯인지 리턴
				
	return -1
"

