[sub_resource type="GDScript" id="GDScript_ku0vp"]
script/source = "extends Area2D

@export_enum(\"normal\", \"hurt\", \"enemy\", \"guide\")
var obstacle_type: String = \"hurt\"

func _ready() -> void:
	area_entered.connect(_on_area_entered)
	
func _on_area_entered(area) -> void:
	match obstacle_type:
		\"normal\":
			print(\"충돌\")
		\"hurt\":
			print(\"부상 입음\")
		\"enemy\":
			print(\"적과 조우\")
		\"guide\":
			print(\"표지판에 도달\")
		
		
"

